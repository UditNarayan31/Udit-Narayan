{% doc %}
  @prompt
    add color options
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-color-options-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-color-options-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-color-options-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font }};
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin: 0;
  }

  .ai-color-options-swatches-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.swatch_spacing }}px;
  }

  .ai-color-option-{{ ai_gen_id }} {
    position: relative;
    cursor: pointer;
  }

  .ai-color-option-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .ai-color-swatch-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: {{ block.settings.swatch_border_radius }}px;
    border: {{ block.settings.swatch_border_width }}px solid {{ block.settings.swatch_border_color }};
    transition: all 0.2s ease;
    position: relative;
  }

  .ai-color-option-input-{{ ai_gen_id }}:checked + .ai-color-swatch-{{ ai_gen_id }} {
    border-color: {{ block.settings.selected_border_color }};
    border-width: {{ block.settings.selected_border_width }}px;
    box-shadow: 0 0 0 {{ block.settings.selected_ring_width }}px {{ block.settings.selected_ring_color }};
  }

  .ai-color-option-input-{{ ai_gen_id }}:checked + .ai-color-swatch-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    background-color: {{ block.settings.checkmark_color }};
    border-radius: 50%;
    opacity: {{ block.settings.show_checkmark | times: 1 }};
  }

  .ai-color-option-{{ ai_gen_id }}:hover .ai-color-swatch-{{ ai_gen_id }} {
    transform: scale(1.1);
  }

  .ai-color-option-{{ ai_gen_id }}:focus-within .ai-color-swatch-{{ ai_gen_id }} {
    outline: 2px solid {{ block.settings.selected_border_color }};
    outline-offset: 2px;
  }

  .ai-color-name-{{ ai_gen_id }} {
    display: {{ block.settings.show_color_names | times: 1 | at_least: 0 | times: 1 | plus: 0 }};
    font-size: 12px;
    color: {{ block.settings.label_color }};
    text-align: center;
    margin-top: 4px;
  }

  {% if block.settings.show_color_names %}
    .ai-color-name-{{ ai_gen_id }} {
      display: block;
    }
  {% else %}
    .ai-color-name-{{ ai_gen_id }} {
      display: none;
    }
  {% endif %}
{% endstyle %}

<color-options-{{ ai_gen_id }} class="ai-color-options-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-color-options-container-{{ ai_gen_id }}">
    {% if block.settings.label != blank %}
      <label class="ai-color-options-label-{{ ai_gen_id }}">{{ block.settings.label }}</label>
    {% endif %}

    <div class="ai-color-options-swatches-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign color_enabled_key = 'color_' | append: i | append: '_enabled'
          assign color_value_key = 'color_' | append: i | append: '_value'
          assign color_name_key = 'color_' | append: i | append: '_name'
          
          assign color_enabled = block.settings[color_enabled_key]
          assign color_value = block.settings[color_value_key]
          assign color_name = block.settings[color_name_key]
        %}

        {% if color_enabled %}
          <div class="ai-color-option-{{ ai_gen_id }}">
            <input
              type="radio"
              name="color-{{ ai_gen_id }}"
              id="color-{{ ai_gen_id }}-{{ i }}"
              value="{{ color_name }}"
              class="ai-color-option-input-{{ ai_gen_id }}"
              {% if i == 1 %}checked{% endif %}
            >
            <label for="color-{{ ai_gen_id }}-{{ i }}">
              <span
                class="ai-color-swatch-{{ ai_gen_id }}"
                style="background-color: {{ color_value }};"
                aria-label="{{ color_name }}"
              ></span>
              {% if block.settings.show_color_names and color_name != blank %}
                <span class="ai-color-name-{{ ai_gen_id }}">{{ color_name }}</span>
              {% endif %}
            </label>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</color-options-{{ ai_gen_id }}>

<script>
  (function() {
    class ColorOptions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.inputs = this.querySelectorAll('.ai-color-option-input-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.inputs.forEach((input) => {
          input.addEventListener('change', (event) => {
            const selectedColor = event.target.value;
            this.dispatchEvent(new CustomEvent('colorchange', {
              detail: { color: selectedColor },
              bubbles: true
            }));
          });
        });
      }
    }

    customElements.define('color-options-{{ ai_gen_id }}', ColorOptions{{ ai_gen_id }});
  })();
</script>

